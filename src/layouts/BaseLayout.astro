---
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  noindex?: boolean;
}

const { title, description, noindex = false } = Astro.props;

const FAVICON =
  "data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 38 38'%3E%3Crect width='38' height='38' rx='7' fill='%23F7F5F0'/%3E%3Cg fill='none' stroke='%233E8A95' stroke-width='2' stroke-linejoin='round' stroke-linecap='round'%3E%3Cpath d='M5 18 L19 6.5 L33 18'/%3E%3Cpath d='M8.5 15.5 V31.5 H29.5 V15.5'/%3E%3Cpath d='M16 31.5 V23 H22 V31.5'/%3E%3C/g%3E%3C/svg%3E";
---
<!DOCTYPE html>
<html lang="hu">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex" />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Spectral:ital,wght@0,500;0,600;0,700;1,600&family=IBM+Plex+Sans:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site).href} />
    <link rel="icon" href={FAVICON} />
    <meta name="theme-color" content="#F7F5F0" />
    <meta name="generator" content={Astro.generator} />
    <slot name="head" />
  </head>
  <body>
    <slot />
  </body>
</html>
