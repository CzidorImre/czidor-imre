---
// Stat strip + client/institution strip, sitting directly under the hero.
---
<!-- stat bar -->
<div class="statbar">
  <div class="wrap">
    <div class="stat"><div class="n"><em>1984</em></div><div class="l">Szakmai kezdés</div></div>
    <div class="stat"><div class="n">40+</div><div class="l">Év tapasztalat</div></div>
    <div class="stat"><div class="n">30+</div><div class="l">Referencia&shy;projekt</div></div>
  </div>
</div>

<!-- client / institution strip -->
<div class="clients" aria-label="Megbízók">
  <div class="wrap clients-in">
    <span class="clients-lbl mono">Megbízóim közt</span>
    <ul class="clients-row">
      <li>JET Transzport International Kft.</li>
      <li>Tiszaújváros Önkormányzata</li>
      <li>BorsodChem térsége</li>
      <li>Eger — társasház-beruházók</li>
      <li>Magánépíttetők</li>
      <li>Ingatlanfejlesztők</li>
    </ul>
  </div>
</div>
