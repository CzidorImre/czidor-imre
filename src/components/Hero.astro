---
// Hero — auto-built 3D house. The #scene canvas is mounted by the bundled
// Three.js module (src/scripts/scene.js). /site.js plays the build animation
// once on load and drives the build progress bar (#build-bar-i).
---
<section class="hero" id="top">
  <div class="hero-track" id="hero-track">
    <div class="hero-sticky">
      <div id="scene" aria-hidden="true"></div>
      <div class="hero-veil" aria-hidden="true"></div>
      <div class="wrap hero-in">
        <div class="hero-grid">
          <div>
            <h1>
              <span class="ln"><span>Az építtető</span></span>
              <span class="ln"><span>oldalán a szerződéskötéstől</span></span>
              <span class="ln"><span>a használatbavételig</span></span>
            </h1>
            <p class="sub">Független, szakértő építési műszaki ellenőrzés és felelős műszaki vezetés Miskolcon és a régióban. Minőség, határidő és költség folyamatos kontroll alatt.</p>
            <div class="cta-row">
              <a href="#kapcsolat" class="btn btn-primary">Kapcsolatfelvétel <span class="arr" aria-hidden="true">→</span></a>
              <a href="#referenciak" class="btn btn-ghost">Referenciák megtekintése</a>
            </div>
          </div>
        </div>
      </div>

      <!-- replay build -->
      <button class="replay-btn" id="replay-btn" type="button" aria-label="Építés újralejátszása"><svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 12a9 9 0 1 0 3-6.7M3 4v4h4" stroke-linecap="round" stroke-linejoin="round"/></svg><span>Újra</span></button>

      <!-- overall build progress -->
      <div class="build-bar" aria-hidden="true"><i id="build-bar-i"></i></div>
    </div>
  </div>
</section>
