---
// Hero — scroll-built 3D house. The #scene canvas is mounted by the bundled
// Three.js module (src/scripts/scene.js). /site.js reads the #hero-track scroll
// position and drives the build progress (#build-bar) + the drag hint.
---
<section class="hero" id="top">
  <div class="hero-track" id="hero-track">
    <div class="hero-sticky">
      <div id="scene" aria-hidden="true"></div>
      <div class="hero-veil" aria-hidden="true"></div>
      <div class="wrap hero-in">
        <div class="hero-grid">
          <div>
            <div class="hero-eyebrow eyebrow"><span class="dot" aria-hidden="true"></span><span class="mono">Czidor Imre · 1984 óta az építőiparban</span></div>
            <h1>
              <span class="ln"><span>Az építtető</span></span>
              <span class="ln"><span>oldalán, <em>a tervtől</em></span></span>
              <span class="ln"><span>a kulcsig.</span></span>
            </h1>
            <p class="sub">Független, szakértő építési műszaki ellenőrzés és felelős műszaki vezetés. Minőség, határidő és költség, folyamatos kontroll alatt, lakóépülettől a nehézipari alapozásig.</p>
            <div class="cta-row">
              <a href="#kapcsolat" class="btn btn-primary">Díjmentes konzultáció <span class="arr" aria-hidden="true">→</span></a>
              <a href="#referenciak" class="btn btn-ghost">Referenciák megtekintése</a>
            </div>
          </div>
        </div>
      </div>

      <!-- scroll / drag hint -->
      <div class="drag-hint" id="drag-hint" aria-hidden="true">
        <span class="ring"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M12 4v14M12 18l-5-5M12 18l5-5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
        <span class="mono" id="drag-hint-t">Görgess, épül a ház</span>
      </div>

      <!-- replay build -->
      <button class="replay-btn" id="replay-btn" type="button" aria-label="Építés újralejátszása"><svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 12a9 9 0 1 0 3-6.7M3 4v4h4" stroke-linecap="round" stroke-linejoin="round"/></svg><span>Újra</span></button>

      <!-- overall build progress -->
      <div class="build-bar" aria-hidden="true"><i id="build-bar-i"></i></div>
    </div>
  </div>
</section>
